<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sistema de Saúde</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
            .navbar-brand {
                font-weight: bold;
            }

            .nav-link:hover {
                color: #0d6efd !important;
            }

            .topbar {
                background-color: #0d6efd;
                color: white;
                font-size: 14px;
                padding: 5px 0;
            }
    </style>
</head>

<body class="d-flex flex-column min-vh-100">

    <!-- BARRA SUPERIOR (estilo governo) -->
    <div class="topbar text-center">
        Sistema de Gestão de Saúde Pública
    </div>

    <!-- NAVBAR -->
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm">
            <div class="container-fluid">

                <a class="navbar-brand text-primary" asp-controller="Home" asp-action="Index">
                    🏥 Saúde+ Gestão
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarMain">

                    <!-- MENU PRINCIPAL -->
                    <ul class="navbar-nav me-auto">

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Início</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Paciente" asp-action="Index">Pacientes</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="AgenteSaude" asp-action="Index">Agentes de Saúde</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="UnidadeAtendimento" asp-action="Index">Unidades</a>
                        </li>

                        <!-- DROPDOWN -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                Cadastros
                            </a>

                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Categoria" asp-action="Index">Categorias</a></li>
                                <li><a class="dropdown-item" asp-controller="Mensagem" asp-action="Index">Mensagens</a></li>
                                <li><a class="dropdown-item" asp-controller="Area" asp-action="Index">Áreas</a></li>
                                <li><a class="dropdown-item" asp-controller="Comorbidade" asp-action="Index">Comorbidades</a></li>
                                <li><a class="dropdown-item" asp-controller="Microarea" asp-action="Index">Microáreas</a></li>
                            </ul>
                        </li>

                    </ul>

                    <!-- DIREITA -->
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Privacy">Privacidade</a>
                        </li>
                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <!-- CONTEÚDO -->
    <div class="container mt-4 flex-grow-1">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <!-- FOOTER -->
    <footer class="bg-light text-center mt-5 p-3 border-top">
        <p class="mb-0">© 2026 - Sistema de Saúde Pública</p>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>